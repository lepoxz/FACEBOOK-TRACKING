generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Source {
  id                  Int             @id @default(autoincrement())
  pageSlug            String          @unique @map("page_slug")
  pageName            String          @map("page_name")
  enabled             Boolean         @default(true)
  realtimeScanEnabled Boolean         @default(false) @map("realtime_scan_enabled")
  telegramTarget      String?         @map("telegram_target")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  jobs                Job[]
  sheetRegistries     SheetRegistry[]

  @@map("sources")
}

model Job {
  id           Int       @id @default(autoincrement())
  sourceId     Int       @map("source_id")
  type         JobType
  status       JobStatus @default(PENDING)
  startedAt    DateTime? @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at")
  source       Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, status])
  @@map("jobs")
}

model SheetRegistry {
  id             Int      @id @default(autoincrement())
  sourceId       Int      @map("source_id")
  date           String
  fileName       String   @map("file_name")
  googleSheetId  String   @map("google_sheet_id")
  googleSheetUrl String   @map("google_sheet_url")
  createdAt      DateTime @default(now()) @map("created_at")
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, date])
  @@map("sheet_registry")
}

enum JobType {
  REALTIME_SCAN
  SCAN_LAST10
  DAILY_REPORT
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
