generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TrackingMode {
  public_activity
}

enum TrackedPageStatus {
  draft
  active
  paused
}

enum TrackingRunStatus {
  queued
  running
  succeeded
  failed
}

enum SnapshotSource {
  crawl
  manual_import
}

model TrackedPage {
  id                   String            @id @default(cuid())
  pageId               String            @unique
  pageName             String
  pageUrl              String
  mode                 TrackingMode      @default(public_activity)
  status               TrackedPageStatus @default(draft)
  checkIntervalMinutes Int               @default(15)
  notes                String?
  lastCheckedAt        DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  snapshots            PageSnapshot[]
  trackingRuns         TrackingRun[]
}

model TrackingRun {
  id            String            @id @default(cuid())
  trackedPageId String
  status        TrackingRunStatus @default(queued)
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  trackedPage   TrackedPage       @relation(fields: [trackedPageId], references: [id], onDelete: Cascade)

  @@index([trackedPageId, status])
}

model PageSnapshot {
  id             String         @id @default(cuid())
  trackedPageId  String
  source         SnapshotSource @default(crawl)
  observedAt     DateTime
  followerCount  Int?
  likeCount      Int?
  talkingAbout   Int?
  postCount24h   Int?
  rawPayload     Json?
  createdAt      DateTime       @default(now())
  trackedPage    TrackedPage    @relation(fields: [trackedPageId], references: [id], onDelete: Cascade)

  @@index([trackedPageId, observedAt])
}
